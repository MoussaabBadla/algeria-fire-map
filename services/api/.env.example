# --- NASA FIRMS ---
# Get a free MAP_KEY here: https://firms.modaps.eosdis.nasa.gov/api/area/
# (Enter your email under "Get MAP_KEY" — it's issued instantly.)
NASA_FIRMS_MAP_KEY=

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000

# --- Redis (optional) ---
# Leave empty for local dev (an in-memory cache is used instead).
# In production (Railway), set this to your Redis URL.
REDIS_URL=

# --- Cache ---
FIRES_CACHE_TTL=600
